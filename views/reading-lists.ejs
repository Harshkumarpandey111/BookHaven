<%- include('partials/header') %>

<div class="mt-page">
  <section class="section section-dark">
    <div class="container" style="max-width:900px">

      <% if (typeof sharedView !== 'undefined' && sharedView) { %>
        <div class="section-label">Shared Collection</div>
        <h2 class="section-title" style="margin-bottom:.5rem"><%= lists[0].name %></h2>
        <p style="color:var(--text-2);margin-bottom:2rem">Curated by <strong style="color:var(--gold)"><%= sharedOwner %></strong></p>
      <% } else { %>
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem;margin-bottom:2rem">
          <div>
            <div class="section-label">Collections</div>
            <h2 class="section-title">My Reading Lists</h2>
          </div>

          <button type="button" class="btn-primary-gold" onclick="document.getElementById('newListModal').style.display='flex'">
            <i class="fas fa-plus"></i> New Collection
          </button>
        </div>

        <!-- Create list modal -->
        <div id="newListModal" style="display:none;position:fixed;inset:0;z-index:3000;background:rgba(0,0,0,.6);align-items:center;justify-content:center;">
          <div style="background:var(--ink-2);border:1px solid var(--border-2);border-radius:var(--r-xl);padding:2rem;max-width:440px;width:90%;animation:fadeUp .3s var(--ease)">
            <h3 style="color:var(--cream);margin-bottom:1.5rem;font-size:1.25rem">Create Collection</h3>
            <form action="/lists" method="POST">
              <div class="form-group">
                <label class="form-label">Collection Name</label>
                <input type="text" name="name" class="form-input" placeholder="e.g. My Partition Novels" required maxlength="80">
              </div>
              <div class="form-group">
                <label class="form-label">Description (optional)</label>
                <input type="text" name="description" class="form-input" placeholder="A brief description..." maxlength="300">
              </div>
              <div class="form-group" style="display:flex;align-items:center;gap:8px">
                <input type="checkbox" name="isPublic" id="listPublic" style="accent-color:var(--gold)">
                <label for="listPublic" style="font-size:.85rem;color:var(--text-2);cursor:pointer">Make this collection public (shareable link)</label>
              </div>
              <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:1.5rem">
                <button type="button" class="btn-ghost" onclick="document.getElementById('newListModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-primary-gold">Create</button>
              </div>
            </form>
          </div>
        </div>
      <% } %>

      <% if (lists.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">📚</div>
          <h4>No collections yet</h4>
          <p>Create your first reading list to organize your books. <a href="/books">Browse books</a></p>
        </div>
      <% } else { %>
        <div style="display:grid;gap:1.5rem">
          <% lists.forEach(list => { %>
            <div class="collection-card" style="background:var(--ink-2);border:1px solid var(--border);border-radius:var(--r-lg);padding:1.5rem;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem">
                <div>
                  <h3 style="color:var(--cream);font-size:1.1rem;margin-bottom:.25rem"><%= list.name %></h3>
                  <% if (list.description) { %>
                    <p style="color:var(--text-3);font-size:.85rem"><%= list.description %></p>
                  <% } %>
                  <div style="display:flex;gap:.75rem;margin-top:.5rem;flex-wrap:wrap">
                    <span style="font-size:.75rem;color:var(--text-3)"><i class="fas fa-book" style="color:var(--gold)"></i> <%= list.books.length %> books</span>
                    <% if (list.isPublic) { %>
                      <span style="font-size:.75rem;color:var(--green)"><i class="fas fa-globe"></i> Public</span>
                    <% } %>
                  </div>
                </div>
                <% if (typeof sharedView === 'undefined' || !sharedView) { %>
                  <div style="display:flex;gap:.5rem">
                    <% if (list.isPublic) { %>
                      <button type="button" class="reader-btn" title="Copy share link"
                        onclick="navigator.clipboard.writeText(window.location.origin+'/lists/shared/<%= list.shareSlug %>');showToast('success','Share link copied!')">
                        <i class="fas fa-link"></i>
                      </button>
                    <% } %>
                    <form action="/lists/<%= list._id %>/delete" method="POST" style="display:inline">
                      <button type="submit" class="reader-btn" title="Delete" style="color:var(--red)" onclick="return confirm('Delete this collection?')">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </div>
                <% } %>
              </div>

              <% if (list.books.length > 0) { %>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:.75rem">
                  <% list.books.forEach(bookId => { %>
                    <% const book = bookMap[bookId]; %>
                    <% if (book) { %>
                      <div style="position:relative;cursor:pointer" onclick="location.href='/books/<%= book.id %>'">
                        <div style="aspect-ratio:2/3;border-radius:8px;overflow:hidden;background:var(--ink-3)">
                          <img src="<%= book.cover %>" alt="<%= book.title %>" style="width:100%;height:100%;object-fit:cover" loading="lazy">
                        </div>
                        <p style="font-size:.72rem;color:var(--cream);margin-top:.35rem;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"><%= book.title %></p>
                        <% if (typeof sharedView === 'undefined' || !sharedView) { %>
                          <form action="/lists/<%= list._id %>/remove/<%= book.id %>" method="POST" style="position:absolute;top:4px;right:4px" onclick="event.stopPropagation()">
                            <button type="submit" style="width:22px;height:22px;border-radius:50%;background:rgba(0,0,0,.7);border:none;color:var(--red);font-size:.6rem;cursor:pointer;display:grid;place-items:center" title="Remove">
                              <i class="fas fa-times"></i>
                            </button>
                          </form>
                        <% } %>
                      </div>
                    <% } %>
                  <% }) %>
                </div>
              <% } else { %>
                <p style="color:var(--text-3);font-size:.85rem;padding:1rem 0">No books added yet. <a href="/books" style="color:var(--gold)">Browse and add books</a></p>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>

    </div>
  </section>
</div>

<%- include('partials/footer') %>
