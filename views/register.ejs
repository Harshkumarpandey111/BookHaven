<%- include('partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-mark"><i class="fas fa-feather-alt"></i></div>
      <span class="nav-logo-name" style="font-size:1.1rem">Lea<span>fr</span></span>
    </div>

    <h2 class="auth-title">Create your account</h2>
    <p class="auth-sub">Join thousands of readers on Leafr — free forever</p>

    <form action="/register" method="POST">
      <div class="form-group">
        <label class="form-label">Full name</label>
        <input type="text" name="name" class="form-input" placeholder="Your name" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">Email address</label>
        <input type="email" name="email" class="form-input" placeholder="you@example.com" required>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-input" placeholder="Min 6 characters" minlength="6" required>
      </div>
      <div class="form-group">
        <label class="form-label">Confirm password</label>
        <input type="password" name="confirm" class="form-input" placeholder="Re-enter your password" required>
      </div>
      <button type="submit" class="btn-auth-submit">
        <i class="fas fa-user-plus"></i> Create account
      </button>
    </form>

    <p class="auth-switch">
      Already have an account? <a href="/login">Sign in</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
