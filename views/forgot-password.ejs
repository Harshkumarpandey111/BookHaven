<%- include('partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-mark"><i class="fas fa-key"></i></div>
      <span class="nav-logo-name" style="font-size:1.1rem">Lea<span>fr</span></span>
    </div>

    <h2 class="auth-title">Forgot password?</h2>
    <p class="auth-sub">We will send an OTP to your registered email</p>

    <form action="/forgot-password" method="POST">
      <div class="form-group">
        <label class="form-label">Email address</label>
        <input type="email" name="email" class="form-input" placeholder="you@example.com" required autofocus>
      </div>
      <button type="submit" class="btn-auth-submit">
        <i class="fas fa-paper-plane"></i> Send OTP
      </button>
    </form>

    <p class="auth-switch">
      Remembered your password? <a href="/login">Back to sign in</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
