<%- include('partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-mark"><i class="fas fa-shield-check"></i></div>
      <span class="nav-logo-name" style="font-size:1.1rem">Lea<span>fr</span></span>
    </div>

    <h2 class="auth-title">Verify your email</h2>
    <p class="auth-sub">Enter the 6-digit OTP sent to your email</p>

    <form action="/verify-email" method="POST">
      <div class="form-group">
        <label class="form-label">Email address</label>
        <input type="email" name="email" class="form-input" value="<%= email %>" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">OTP code</label>
        <input type="text" name="otp" class="form-input" placeholder="6-digit OTP" minlength="6" maxlength="6" pattern="[0-9]{6}" required>
      </div>
      <button type="submit" class="btn-auth-submit">
        <i class="fas fa-check-circle"></i> Verify email
      </button>
    </form>

    <p class="auth-switch">
      Wrong email? <a href="/register">Register again</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
