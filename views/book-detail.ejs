<%- include('partials/header') %>

<div class="mt-page">
<section class="section section-dark">
  <div class="container">

    <div class="breadcrumb-custom">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <a href="/books">Library</a>
      <span class="breadcrumb-sep">/</span>
      <span style="color:var(--text-2)"><%= book.title %></span>
    </div>

    <div class="detail-layout">

      <!-- LEFT — Cover + Actions -->
      <div class="detail-cover-sticky">
        <div class="detail-cover-frame">
          <img src="<%= book.cover %>" alt="<%= book.title %>">
        </div>

        <div class="detail-actions">
          <% if (!user) { %>
            <a href="/login" class="btn-read-full">
              <i class="fas fa-book-reader"></i> Sign in to Read Free
            </a>
            <a href="/login" class="btn-buy-full">
              <i class="fas fa-shopping-cart"></i> Sign in to Buy — ₹<%= book.price %>
            </a>
          <% } else { %>
            <% const alreadyRead  = userData && userData.readBooks      && userData.readBooks.includes(book.id) %>
            <% const alreadyBought= userData && userData.purchasedBooks && userData.purchasedBooks.includes(book.id) %>
            <% const inCart       = userData && userData.cart           && userData.cart.includes(book.id) %>
            <% const progressPct  = readingProgress && readingProgress.progressPercent ? readingProgress.progressPercent : 0 %>

            <a href="/books/<%= book.id %>/read" class="btn-read-full">
              <i class="fas fa-<%= alreadyRead ? 'book-open' : 'book-reader' %>"></i>
              <%= alreadyRead ? `Continue Reading (${progressPct}%)` : `Read Free Preview (${previewPercent}%)` %>
            </a>

            <% if (alreadyBought) { %>
              <button class="btn-buy-full purchased" disabled>
                <i class="fas fa-check-circle"></i> In Your Library
              </button>
            <% } else if (inCart) { %>
              <a href="/user/dashboard" class="btn-buy-full in-cart">
                <i class="fas fa-shopping-cart"></i> View in Cart
              </a>
            <% } else { %>
              <button class="btn-buy-full" id="buyBtn" onclick="addToCart(<%= book.id %>, this)">
                <i class="fas fa-shopping-bag"></i> Buy Now — ₹<%= book.price %>
              </button>
            <% } %>

            <button class="btn-buy-full" type="button" data-wishlist-book="<%= book.id %>" onclick="toggleWishlist(<%= book.id %>, this)">
              <i class="fas fa-heart <%= wishlistEntry ? 'wishlist-active' : '' %>"></i>
              <%= wishlistEntry ? 'Saved to Wishlist' : 'Save to Wishlist' %>
            </button>
          <% } %>
        </div>

        <!-- Meta Pills -->
        <div class="detail-meta-pills" style="margin-top:1.25rem">
          <div class="detail-meta-pill rating">
            <i class="fas fa-star"></i> <%= book.rating %> / 5.0
          </div>
          <div class="detail-meta-pill">
            <i class="fas fa-file-alt"></i> <%= book.pages %> pages
          </div>
          <div class="detail-meta-pill">
            <i class="fas fa-tag"></i> ₹<%= book.price %>
          </div>
          <div class="detail-meta-pill">
            <i class="fas fa-globe"></i> <%= book.origin %>
          </div>
        </div>
      </div>

      <!-- RIGHT — Info + Tabs -->
      <div>
        <div class="book-cat" style="margin-bottom:8px"><%= book.category %></div>
        <h1 class="detail-book-title"><%= book.title %></h1>
        <p class="detail-book-author">by <span><%= book.author %></span></p>

        <!-- TABS -->
        <div class="detail-tabs">
          <div class="detail-tab active" data-tab="about">About</div>
          <div class="detail-tab" data-tab="index">Index</div>
          <div class="detail-tab" data-tab="preview">Preview</div>
          <div class="detail-tab" data-tab="reviews">Reviews (<%= reviewStats.count %>)</div>
        </div>

        <!-- ABOUT TAB -->
        <div class="detail-tab-content active" id="tab-about">
          <p class="detail-description"><%= book.description %></p>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1.5rem">
            <div style="background:var(--ink-2);border:1px solid var(--border);border-radius:var(--r);padding:1rem">
              <div style="font-size:.7rem;color:var(--text-3);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px">Author</div>
              <div style="font-family:'Fraunces',serif;color:var(--cream);font-size:.95rem"><%= book.author %></div>
            </div>
            <div style="background:var(--ink-2);border:1px solid var(--border);border-radius:var(--r);padding:1rem">
              <div style="font-size:.7rem;color:var(--text-3);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px">Origin</div>
              <div style="font-family:'Fraunces',serif;color:var(--cream);font-size:.95rem"><%= book.origin %></div>
            </div>
            <div style="background:var(--ink-2);border:1px solid var(--border);border-radius:var(--r);padding:1rem">
              <div style="font-size:.7rem;color:var(--text-3);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px">Pages</div>
              <div style="font-family:'Fraunces',serif;color:var(--cream);font-size:.95rem"><%= book.pages %></div>
            </div>
            <div style="background:var(--ink-2);border:1px solid var(--border);border-radius:var(--r);padding:1rem">
              <div style="font-size:.7rem;color:var(--text-3);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px">Genre</div>
              <div style="font-family:'Fraunces',serif;color:var(--cream);font-size:.95rem"><%= book.category %></div>
            </div>
          </div>
        </div>

        <!-- INDEX TAB -->
        <div class="detail-tab-content" id="tab-index">
          <p style="color:var(--text-2);font-size:.875rem;margin-bottom:1.25rem">Table of Contents — <%= book.pages %> pages across the following chapters:</p>
          <%
            const lines = book.fullText.split('\n\n');
            const chapters = lines.filter(l =>
              l.match(/^(Chapter|Part|Prologue|Introduction|Section|Song|Book|Act)/i)
            );
            const chapterList = chapters.length > 0 ? chapters : ['Introduction', 'Part One', 'Part Two', 'Part Three', 'Conclusion'];
            let pageNum = 1;
          %>
          <ul class="book-index">
            <% chapterList.slice(0,12).forEach((ch, i) => {
              const pg = pageNum;
              pageNum += Math.floor(book.pages / Math.max(chapterList.length, 1)) + Math.floor(Math.random()*8);
            %>
            <li>
              <span class="idx-num"><%= (i+1).toString().padStart(2,'0') %></span>
              <span class="idx-title"><%= ch.split('\n')[0].trim() %></span>
              <span class="idx-pg">p.<%= Math.min(pg, book.pages) %></span>
            </li>
            <% }) %>
          </ul>
          <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--border)">
            <a href="/books/<%= book.id %>/read" style="color:var(--gold);font-size:.875rem">
              <i class="fas fa-book-reader me-1"></i> Open preview reader (<%= previewPercent %>% free) →
            </a>
          </div>
        </div>

        <!-- PREVIEW TAB -->
        <div class="detail-tab-content" id="tab-preview">
          <div class="preview-text-block">
            <div class="preview-quote-mark">"</div>
            <p><%= book.preview %></p>
            <div class="preview-fade"></div>
          </div>
          <div style="margin-top:1rem;display:flex;align-items:center;gap:1rem">
            <a href="/books/<%= book.id %>/read" class="btn-primary-gold" style="padding:10px 20px;font-size:.85rem">
              <i class="fas fa-book-open"></i> Continue reading
            </a>
            <span style="color:var(--text-3);font-size:.8rem">Only <%= previewPercent %>% is free. Full text unlocks after purchase.</span>
          </div>
        </div>

        <!-- REVIEWS TAB -->
        <div class="detail-tab-content" id="tab-reviews">
          <div class="reviews-summary">
            <div class="reviews-summary-score"><%= reviewStats.average.toFixed ? reviewStats.average.toFixed(1) : reviewStats.average %></div>
            <div>
              <div class="reviews-summary-label">Average rating</div>
              <div class="reviews-summary-sub"><%= reviewStats.count %> review<%= reviewStats.count === 1 ? '' : 's' %></div>
            </div>
          </div>

          <% if (user) { %>
            <form action="/books/<%= book.id %>/reviews" method="POST" class="review-form">
              <div class="review-form-row">
                <label>
                  Rating
                  <select name="rating" required>
                    <option value="5" <%= userReview && userReview.rating === 5 ? 'selected' : '' %>>5 - Excellent</option>
                    <option value="4" <%= userReview && userReview.rating === 4 ? 'selected' : '' %>>4 - Good</option>
                    <option value="3" <%= userReview && userReview.rating === 3 ? 'selected' : '' %>>3 - Average</option>
                    <option value="2" <%= userReview && userReview.rating === 2 ? 'selected' : '' %>>2 - Poor</option>
                    <option value="1" <%= userReview && userReview.rating === 1 ? 'selected' : '' %>>1 - Bad</option>
                  </select>
                </label>
              </div>
              <label>
                Your review
                <textarea name="comment" rows="4" placeholder="Share your thoughts about this book" required><%= userReview ? userReview.comment : '' %></textarea>
              </label>
              <button type="submit" class="btn-primary-gold">
                <i class="fas fa-paper-plane"></i> <%= userReview ? 'Update Review' : 'Post Review' %>
              </button>
            </form>
          <% } else { %>
            <div class="empty-state" style="margin-bottom:1rem">
              <div class="empty-state-icon">✍️</div>
              <h4>Sign in to review</h4>
              <p>Share your opinion and help other readers decide.</p>
            </div>
          <% } %>

          <div class="review-list">
            <% if (reviews.length === 0) { %>
              <div class="empty-state">
                <div class="empty-state-icon">💬</div>
                <h4>No reviews yet</h4>
                <p>Be the first to review this book.</p>
              </div>
            <% } else { %>
              <% reviews.forEach((review) => { %>
                <div class="review-card">
                  <div class="review-card-head">
                    <div>
                      <div class="review-author"><%= review.user && review.user.name ? review.user.name : 'Reader' %></div>
                      <div class="review-date"><%= review.createdAt.toLocaleDateString() %></div>
                    </div>
                    <div class="review-stars">⭐ <%= review.rating %>/5</div>
                  </div>
                  <p class="review-comment"><%= review.comment %></p>
                  <% if (userReview && review._id.toString() === userReview._id.toString()) { %>
                    <form action="/books/<%= book.id %>/reviews/<%= review._id %>/delete" method="POST" style="margin-top:.75rem">
                      <button type="submit" class="admin-link admin-link-danger" onclick="return confirm('Delete your review?')">Delete review</button>
                    </form>
                  <% } %>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
</div>

<%- include('partials/footer') %>
