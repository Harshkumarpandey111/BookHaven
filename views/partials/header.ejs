<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — BookHaven</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script>
    // Apply theme before paint to prevent flash
    (function(){
      var t = localStorage.getItem('bh-theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>

<nav class="nav-root" id="mainNav">
  <a href="/" class="nav-logo">
    <div class="nav-logo-mark"><i class="fas fa-feather-alt"></i></div>
    <span class="nav-logo-name">Book<span>Haven</span></span>
  </a>

  <div class="nav-search">
    <i class="fas fa-search nav-search-icon"></i>
    <form action="/books" method="GET">
      <input type="search" name="search" id="navSearchInput" placeholder="Search books, authors, genres…" autocomplete="off" data-i18n-placeholder="nav_search_placeholder">
    </form>
    <div id="autocompleteDropdown" class="autocomplete-dropdown" style="display:none"></div>
  </div>

  <div class="nav-links">
    <a href="/books" class="nav-link-item" data-i18n="nav_browse">Browse</a>
    <a href="/books?origin=Indian" class="nav-link-item" data-i18n="nav_indian">🇮🇳 Indian</a>

    <% if (user) { %>
      <a href="/wishlist" class="nav-link-item" data-i18n="nav_wishlist">Wishlist</a>
      <% if (user.role === 'admin') { %>
        <a href="/admin/dashboard" class="nav-link-item">Admin</a>
      <% } %>

      <!-- Notification Bell -->
      <div class="notif-bell-wrap" id="notifBellWrap">
        <button class="notif-bell-btn" id="notifBellBtn" title="Notifications">
          <i class="fas fa-bell"></i>
          <span class="notif-badge" id="notifBadge" style="display:none">0</span>
        </button>
        <div class="notif-dropdown" id="notifDropdown" style="display:none">
          <div class="notif-dropdown-head">
            <span data-i18n="notif_title">Notifications</span>
            <button class="notif-mark-read" id="notifMarkRead" data-i18n="notif_mark_read">Mark all as read</button>
          </div>
          <div class="notif-dropdown-body" id="notifList">
            <div class="notif-empty" data-i18n="notif_empty">No notifications yet</div>
          </div>
        </div>
      </div>

      <div class="nav-user" onclick="location.href='/user/dashboard'">
        <div class="nav-user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <%= user.name.split(' ')[0] %>
      </div>
      <a href="/logout" class="nav-link-item" data-i18n="nav_logout">Logout</a>
    <% } else { %>
      <a href="/login" class="nav-link-item" data-i18n="nav_signin">Sign in</a>
      <a href="/register" class="btn-nav-cta" data-i18n="nav_get_started">Get started</a>
    <% } %>

    <!-- Theme Toggle -->
    <button class="theme-toggle-btn" id="themeToggle" title="Toggle theme">
      <i class="fas fa-moon" id="themeIcon"></i>
    </button>

    <!-- Language Toggle -->
    <button class="lang-toggle-btn" id="langToggle" title="Switch language">
      <span id="langLabel">EN</span>
    </button>
  </div>
</nav>

<% if (success && success.length > 0) { %>
  <div class="toast-wrap">
    <div class="toast-item success">
      <i class="fas fa-check-circle"></i> <%= success %>
    </div>
  </div>
<% } %>
<% if (error && error.length > 0) { %>
  <div class="toast-wrap">
    <div class="toast-item error">
      <i class="fas fa-exclamation-circle"></i> <%= error %>
    </div>
  </div>
<% } %>
