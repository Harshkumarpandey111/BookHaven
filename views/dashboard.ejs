<%- include('partials/header') %>

<div class="mt-page">
<div class="dash-layout">

  <!-- SIDEBAR -->
  <aside class="dash-sidebar">
    <div class="dash-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
    <div class="dash-username"><%= user.name %></div>
    <div class="dash-email"><%= user.email %></div>

    <nav class="dash-nav">
      <div class="dash-nav-item active" data-section="overview">
        <i class="fas fa-layer-group"></i> <span data-i18n="dash_overview">Overview</span>
        <span class="dash-nav-count"><%= readBooks.length + purchasedBooks.length + wishlistedBooks.length %></span>
      </div>
      <div class="dash-nav-item" data-section="cart">
        <i class="fas fa-shopping-cart"></i> <span data-i18n="dash_cart">Cart</span>
        <span class="dash-nav-count"><%= cartBooks.length %></span>
      </div>
      <div class="dash-nav-item" data-section="library">
        <i class="fas fa-bookmark"></i> <span data-i18n="dash_my_library">My Library</span>
        <span class="dash-nav-count"><%= purchasedBooks.length %></span>
      </div>
      <div class="dash-nav-item" data-section="history">
        <i class="fas fa-clock"></i> <span data-i18n="dash_reading_history">Reading History</span>
        <span class="dash-nav-count"><%= readBooks.length %></span>
      </div>
      <div class="dash-nav-item" data-section="wishlist">
        <i class="fas fa-heart"></i> <span data-i18n="dash_wishlist">Wishlist</span>
        <span class="dash-nav-count"><%= wishlistedBooks.length %></span>
      </div>
      <div class="dash-nav-item" data-section="orders">
        <i class="fas fa-receipt"></i> Orders
        <span class="dash-nav-count"><%= paidOrders.length %></span>
      </div>
    </nav>

    <div style="margin-top:auto;padding-top:2rem;border-top:1px solid var(--border);margin-top:2rem">
      <a href="/lists" style="display:flex;align-items:center;gap:8px;font-size:.8rem;color:var(--text-3);padding:8px 0;transition:color .2s" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-3)'">
        <i class="fas fa-layer-group"></i> <span data-i18n="dash_collections">Collections</span>
      </a>
      <a href="/books" style="display:flex;align-items:center;gap:8px;font-size:.8rem;color:var(--text-3);padding:8px 0;transition:color .2s" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-3)'">
        <i class="fas fa-compass"></i> <span data-i18n="dash_browse_library">Browse Library</span>
      </a>
      <a href="/logout" style="display:flex;align-items:center;gap:8px;font-size:.8rem;color:var(--text-3);padding:8px 0;transition:color .2s" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text-3)'">
        <i class="fas fa-sign-out-alt"></i> Sign Out
      </a>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="dash-main">

    <!-- OVERVIEW PANEL -->
    <div id="panel-overview" class="dash-panel active">
      <div style="margin-bottom:2rem">
        <div class="section-label">Dashboard</div>
        <h2 style="font-size:1.75rem;color:var(--cream)" data-i18n="dash_welcome">Welcome back, <%= user.name.split(' ')[0] %></h2>
      </div>

      <!-- Reading Stats -->
      <div class="reading-stats-grid" style="margin-bottom:2rem">
        <div class="reading-stat-card">
          <div class="reading-stat-icon" style="background:rgba(91,156,246,.15);color:var(--blue)">📚</div>
          <div class="reading-stat-num"><%= readingStats.booksThisMonth %></div>
          <div class="reading-stat-label" data-i18n="dash_stats_month">books this month</div>
        </div>
        <div class="reading-stat-card">
          <div class="reading-stat-icon" style="background:rgba(245,158,11,.15);color:#f59e0b">⭐</div>
          <div class="reading-stat-num"><%= readingStats.avgRating %></div>
          <div class="reading-stat-label" data-i18n="dash_stats_rating">avg rating given</div>
        </div>
        <div class="reading-stat-card">
          <div class="reading-stat-icon" style="background:rgba(61,220,151,.15);color:var(--green)">🏆</div>
          <div class="reading-stat-num" style="font-size:1rem"><%= readingStats.topGenre %></div>
          <div class="reading-stat-label" data-i18n="dash_stats_genre">top genre</div>
        </div>
        <div class="reading-stat-card">
          <div class="reading-stat-icon" style="background:rgba(201,168,76,.15);color:var(--gold)">💰</div>
          <div class="reading-stat-num">₹<%= readingStats.totalSpent %></div>
          <div class="reading-stat-label" data-i18n="dash_stats_spent">total spent</div>
        </div>
      </div>

      <div class="dash-stat-grid">
        <div class="dash-stat">
          <div class="dash-stat-icon si-read"><i class="fas fa-book-open"></i></div>
          <div class="dash-stat-num"><%= readBooks.length %></div>
          <div class="dash-stat-label" data-i18n="dash_books_read">Books read</div>
        </div>
        <div class="dash-stat">
          <div class="dash-stat-icon si-bought"><i class="fas fa-bookmark"></i></div>
          <div class="dash-stat-num"><%= purchasedBooks.length %></div>
          <div class="dash-stat-label" data-i18n="dash_books_owned">Books owned</div>
        </div>
        <div class="dash-stat">
          <div class="dash-stat-icon si-cart"><i class="fas fa-shopping-cart"></i></div>
          <div class="dash-stat-num"><%= cartBooks.length %></div>
          <div class="dash-stat-label" data-i18n="dash_in_cart">In cart</div>
        </div>
        <div class="dash-stat">
          <div class="dash-stat-icon si-cart"><i class="fas fa-heart"></i></div>
          <div class="dash-stat-num"><%= wishlistedBooks.length %></div>
          <div class="dash-stat-label" data-i18n="dash_wishlist">Wishlist</div>
        </div>
      </div>

      <% if (cartBooks.length > 0) { %>
      <div style="margin-bottom:2rem">
        <div class="dash-section-title"><i class="fas fa-shopping-cart" style="color:var(--gold)"></i> Cart — <%= cartBooks.length %> item<%= cartBooks.length>1?'s':'' %></div>
        <div class="cart-list">
          <% cartBooks.slice(0,3).forEach(book => { %>
          <div class="cart-row">
            <img src="<%= book.cover %>" class="cart-thumb" alt="<%= book.title %>">
            <div class="cart-info">
              <div class="cart-name"><%= book.title %></div>
              <div class="cart-author"><%= book.author %></div>
            </div>
            <div class="cart-price">₹<%= book.price %></div>
          </div>
          <% }) %>
        </div>
        <% if (cartBooks.length > 3) { %>
          <p style="font-size:.8rem;color:var(--text-3);margin-top:.5rem">+ <%= cartBooks.length-3 %> more items</p>
        <% } %>
        <div style="margin-top:1rem">
          <button class="dash-nav-item" data-section="cart" style="background:none;border:none;color:var(--gold);font-size:.85rem;cursor:pointer;padding:0">View cart & checkout →</button>
        </div>
      </div>
      <% } %>

      <!-- Recent reads -->
      <div class="dash-section-title"><i class="fas fa-clock" style="color:var(--blue)"></i> <span data-i18n="dash_recently_read">Recently Read</span> <span style="color:var(--text-3);font-size:.9rem"><%= totalReadBooks > 0 ? '(' + totalReadBooks + ')' : '' %></span></div>
      <% if (readBooks.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">📖</div>
          <h4 data-i18n="dash_no_history">No reading history yet</h4>
          <p><span data-i18n="dash_no_history_desc">Open any book to start building your reading list.</span> <a href="/books" data-i18n="dash_browse_library">Browse the library</a></p>
        </div>
      <% } else { %>
        <div class="small-book-grid">
          <% readBooks.slice(0,8).forEach(book => { %>
          <% const prog = readingProgressMap && readingProgressMap[book.id] ? readingProgressMap[book.id].progressPercent : 0 %>
          <div class="small-book-card">
            <div class="small-book-cover"><img src="<%= book.cover %>" alt="<%= book.title %>" loading="lazy"></div>
            <div class="small-book-meta">
              <div class="small-book-name"><%= book.title %></div>
              <div class="small-book-auth"><%= book.author %> • <%= prog %>% read</div>
            </div>
            <div class="small-book-hover">
              <button class="small-book-btn" onclick="location.href='/books/<%= book.id %>/read'">Continue</button>
            </div>
            <span class="small-book-label label-read">Read</span>
          </div>
          <% }) %>
        </div>
        <% if (showReadMoreRead) { %>
          <p style="font-size:.85rem;color:var(--text-3);margin-top:1rem">Showing 8 of <%= totalReadBooks %> books. <a href="/user/library" style="color:var(--gold)">View all →</a></p>
        <% } %>
      <% } %>
    </div>

    <!-- CART PANEL -->
    <div id="panel-cart" class="dash-panel" style="display:none">
      <div class="dash-section-title"><i class="fas fa-shopping-cart" style="color:var(--gold)"></i> <span data-i18n="dash_shopping_cart">Shopping Cart</span></div>
      <% if (cartBooks.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">🛒</div>
          <h4 data-i18n="dash_empty_cart">Your cart is empty</h4>
          <p><span data-i18n="dash_empty_cart_desc">Browse the library and add books you want to own.</span> <a href="/books" data-i18n="dash_explore">Explore now</a></p>
        </div>
      <% } else { %>
        <div class="cart-list">
          <% cartBooks.forEach(book => { %>
          <div class="cart-row">
            <img src="<%= book.cover %>" class="cart-thumb" alt="<%= book.title %>">
            <div class="cart-info">
              <div class="cart-name"><%= book.title %></div>
              <div class="cart-author"><%= book.author %></div>
            </div>
            <div class="cart-price">₹<%= book.price %></div>
            <form action="/user/cart/remove/<%= book.id %>" method="POST">
              <button type="submit" class="cart-remove"><i class="fas fa-trash-alt"></i></button>
            </form>
          </div>
          <% }) %>
        </div>

        <div class="checkout-bar">
          <div>
            <div class="checkout-total-label" data-i18n="dash_total">Total</div>
            <div class="checkout-total-amount">₹<%= cartTotal %></div>
          </div>
          <button
            type="button"
            class="btn-checkout"
            data-book-ids='<%- JSON.stringify(cartBooks.map((b) => b.id)) %>'
            onclick="startCheckout(this)">
            <i class="fas fa-credit-card me-2"></i><span data-i18n="dash_pay_securely">Pay Securely</span> — ₹<%= cartTotal %>
          </button>
        </div>
      <% } %>
    </div>

    <!-- LIBRARY PANEL -->
    <div id="panel-library" class="dash-panel" style="display:none">
      <div class="dash-section-title"><i class="fas fa-bookmark" style="color:var(--green)"></i> <span data-i18n="dash_my_library">My Library</span> <span style="color:var(--text-3);font-size:.9rem"><%= totalPurchasedBooks > 0 ? '(' + totalPurchasedBooks + ')' : '' %></span></div>
      <% if (purchasedBooks.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">🏛️</div>
          <h4 data-i18n="dash_empty_library">Your library is empty</h4>
          <p><span data-i18n="dash_empty_library_desc">Purchase books to add them to your permanent collection.</span> <a href="/books">Browse books</a></p>
        </div>
      <% } else { %>
        <div class="small-book-grid">
          <% purchasedBooks.forEach(book => { %>
          <div class="small-book-card">
            <div class="small-book-cover"><img src="<%= book.cover %>" alt="<%= book.title %>" loading="lazy"></div>
            <div class="small-book-meta">
              <div class="small-book-name"><%= book.title %></div>
              <div class="small-book-auth"><%= book.author %></div>
            </div>
            <div class="small-book-hover">
              <button class="small-book-btn" onclick="location.href='/books/<%= book.id %>/read'">Read</button>
            </div>
            <span class="small-book-label label-owned">Owned</span>
          </div>
          <% }) %>
        </div>
        <% if (showReadMorePurchased) { %>
          <p style="font-size:.85rem;color:var(--text-3);margin-top:1rem">Showing <%= purchasedBooks.length %> of <%= totalPurchasedBooks %> books. <a href="/user/library-full" style="color:var(--gold)">View all →</a></p>
        <% } %>
      <% } %>
    </div>

    <!-- HISTORY PANEL -->
    <div id="panel-history" class="dash-panel" style="display:none">
      <div class="dash-section-title"><i class="fas fa-clock" style="color:var(--blue)"></i> <span data-i18n="dash_reading_history">Reading History</span> <span style="color:var(--text-3);font-size:.9rem"><%= totalReadBooks > 0 ? '(' + totalReadBooks + ')' : '' %></span></div>
      <% if (readBooks.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">📚</div>
          <h4>No history yet</h4>
          <p>Every book you open will appear here automatically. <a href="/books">Start reading</a></p>
        </div>
      <% } else { %>
        <div class="small-book-grid">
          <% readBooks.forEach(book => { %>
          <% const prog = readingProgressMap && readingProgressMap[book.id] ? readingProgressMap[book.id].progressPercent : 0 %>
          <div class="small-book-card">
            <div class="small-book-cover"><img src="<%= book.cover %>" alt="<%= book.title %>" loading="lazy"></div>
            <div class="small-book-meta">
              <div class="small-book-name"><%= book.title %></div>
              <div class="small-book-auth"><%= book.author %> • <%= prog %>% read</div>
            </div>
            <div class="small-book-hover">
              <button class="small-book-btn" onclick="location.href='/books/<%= book.id %>/read'">Continue</button>
            </div>
            <span class="small-book-label label-read">Read</span>
          </div>
          <% }) %>
        </div>
        <% if (showReadMoreRead) { %>
          <p style="font-size:.85rem;color:var(--text-3);margin-top:1rem">Showing <%= readBooks.length %> of <%= totalReadBooks %> books.</p>
        <% } %>
      <% } %>
    </div>

    <!-- WISHLIST PANEL -->
    <div id="panel-wishlist" class="dash-panel" style="display:none">
      <div class="dash-section-title"><i class="fas fa-heart" style="color:var(--red)"></i> <span data-i18n="dash_wishlist">Wishlist</span> <span style="color:var(--text-3);font-size:.9rem"><%= totalWishlist > 0 ? '(' + totalWishlist + ')' : '' %></span></div>
      <% if (wishlistedBooks.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">💖</div>
          <h4>No saved books yet</h4>
          <p>Save books from the library to revisit them later. <a href="/books">Browse books</a></p>
        </div>
      <% } else { %>
        <div class="small-book-grid">
          <% wishlistedBooks.forEach(book => { %>
          <div class="small-book-card">
            <div class="small-book-cover"><img src="<%= book.cover %>" alt="<%= book.title %>" loading="lazy"></div>
            <div class="small-book-meta">
              <div class="small-book-name"><%= book.title %></div>
              <div class="small-book-auth"><%= book.author %></div>
            </div>
            <div class="small-book-hover">
              <button class="small-book-btn" onclick="location.href='/books/<%= book.id %>'">Open</button>
            </div>
            <span class="small-book-label label-owned">Saved</span>
          </div>
          <% }) %>
        </div>
        <% if (showReadMoreWishlist) { %>
          <p style="font-size:.85rem;color:var(--text-3);margin-top:1rem">Showing <%= wishlistedBooks.length %> of <%= totalWishlist %> books. <a href="/wishlist" style="color:var(--gold)">View all →</a></p>
        <% } %>
      <% } %>
    </div>

    <!-- ORDERS PANEL -->
    <div id="panel-orders" class="dash-panel" style="display:none">
      <div class="dash-section-title"><i class="fas fa-receipt" style="color:var(--gold)"></i> Order History</div>
      <% if (paidOrders.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">🧾</div>
          <h4>No orders yet</h4>
          <p>Your purchase history will appear here. <a href="/books">Browse books</a></p>
        </div>
      <% } else { %>
        <div style="display:grid;gap:.75rem">
          <% paidOrders.forEach(order => { %>
          <div class="cart-row" style="justify-content:space-between">
            <div class="cart-info" style="flex:1">
              <div class="cart-name"><%= order.receipt %></div>
              <div class="cart-author"><%= new Date(order.paidAt || order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %> • <%= order.books.length %> book(s)</div>
            </div>
            <div class="cart-price" style="margin-right:1rem">₹<%= (order.amount/100).toFixed(0) %></div>
            <a href="/api/receipt/<%= order._id %>" class="btn-ghost" style="padding:6px 14px;font-size:.78rem" target="_blank">
              <i class="fas fa-download"></i> PDF
            </a>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  </main>
</div>
</div>

<script>
// Dashboard panel switching
document.querySelectorAll('[data-section]').forEach(item => {
  item.addEventListener('click', () => {
    const sec = item.dataset.section;
    document.querySelectorAll('.dash-nav-item').forEach(i => i.classList.remove('active'));
    document.querySelectorAll('.dash-panel').forEach(p => p.style.display = 'none');
    document.querySelectorAll(`[data-section="${sec}"]`).forEach(i => {
      if (i.classList.contains('dash-nav-item')) i.classList.add('active');
    });
    const panel = document.getElementById('panel-' + sec);
    if (panel) panel.style.display = 'block';
  });
});
</script>

<%- include('partials/footer') %>
