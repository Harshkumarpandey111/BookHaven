<%- include('partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-mark"><i class="fas fa-lock"></i></div>
      <span class="nav-logo-name" style="font-size:1.1rem">Lea<span>fr</span></span>
    </div>

    <h2 class="auth-title">Reset your password</h2>
    <p class="auth-sub">Verify OTP and set a new password</p>

    <form action="/reset-password" method="POST">
      <div class="form-group">
        <label class="form-label">Email address</label>
        <input type="email" name="email" class="form-input" value="<%= email %>" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">OTP code</label>
        <input type="text" name="otp" class="form-input" placeholder="6-digit OTP" minlength="6" maxlength="6" pattern="[0-9]{6}" required>
      </div>
      <div class="form-group">
        <label class="form-label">New password</label>
        <input type="password" name="password" class="form-input" placeholder="Minimum 8 characters" minlength="8" required>
      </div>
      <div class="form-group">
        <label class="form-label">Confirm new password</label>
        <input type="password" name="confirm" class="form-input" placeholder="Re-enter new password" required>
      </div>
      <button type="submit" class="btn-auth-submit">
        <i class="fas fa-save"></i> Reset password
      </button>
    </form>

    <p class="auth-switch">
      Didn't receive OTP? <a href="/forgot-password">Resend OTP</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
