<%- include('partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-mark"><i class="fas fa-feather-alt"></i></div>
      <span class="nav-logo-name" style="font-size:1.1rem">Book<span>Haven</span></span>
    </div>

    <h2 class="auth-title">Welcome back</h2>
    <p class="auth-sub">Sign in to your reading library</p>

    <form action="/login" method="POST">
      <div class="form-group">
        <label class="form-label">Email address</label>
        <input type="email" name="email" class="form-input" placeholder="you@example.com" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-input" placeholder="••••••••" required>
      </div>
      <p class="auth-switch" style="margin:0 0 12px 0; text-align:right;">
        <a href="/forgot-password">Forgot password?</a>
      </p>
      <button type="submit" class="btn-auth-submit">
        <i class="fas fa-sign-in-alt"></i> Sign in
      </button>
    </form>

    <div class="auth-divider">or</div>

    <a href="/auth/google" class="btn-auth-submit" style="background:#fff;color:#333;border:1px solid var(--border-2);text-decoration:none;margin-bottom:.5rem">
      <svg width="18" height="18" viewBox="0 0 24 24" style="flex-shrink:0"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
      Continue with Google
    </a>

    <p class="auth-switch">
      Don't have an account? <a href="/register">Create one free</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
